{
  "name": "boxes-web",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "sourceRoot": "apps/boxes-web/src",
  "tags": [],
  "// targets": "to see all targets run: nx show project boxes-web --web",
  "targets": {
    "build": {
      "executor": "@nx/vite:build",
      "outputs": ["{options.outputPath}"],
      "options": {
        "outputPath": "dist/apps/boxes-web",
        "configFile": "apps/boxes-web/vite.config.ts",
        "tsConfig": "apps/boxes-web/tsconfig.app.json"
      }
    },
    "serve": {
      "continuous": true,
      "executor": "@nx/vite:dev-server",
      "options": {
        "buildTarget": "boxes-web:build"
      }
    },
    "preview": {
      "continuous": true,
      "executor": "@nx/vite:preview-server",
      "options": {
        "buildTarget": "boxes-web:build"
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint",
      "options": {}
    }
  }
}
