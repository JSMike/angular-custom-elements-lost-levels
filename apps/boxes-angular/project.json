{
  "name": "boxes-angular",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "prefix": "app",
  "sourceRoot": "apps/boxes-angular/src",
  "tags": [],
  "targets": {
    "build": {
      "executor": "@angular/build:application",
      "outputs": ["{options.outputPath}"],
      "options": {
        "outputPath": "dist/apps/boxes-angular",
        "browser": "apps/boxes-angular/src/main.ts",
        "tsConfig": "apps/boxes-angular/tsconfig.app.json",
        "inlineStyleLanguage": "scss",
        "assets": [
          {
            "glob": "**/*",
            "input": "apps/boxes-angular/public"
          }
        ],
        "styles": ["apps/boxes-angular/src/styles.scss"]
      },
      "configurations": {
        "production": {
          "budgets": [
            {
              "type": "initial",
              "maximumWarning": "500kb",
              "maximumError": "1mb"
            },
            {
              "type": "anyComponentStyle",
              "maximumWarning": "4kb",
              "maximumError": "8kb"
            }
          ],
          "outputHashing": "all"
        },
        "development": {
          "optimization": false,
          "extractLicenses": false,
          "sourceMap": {
            "scripts": true,
            "styles": true,
            "vendor": true
          }
        }
      },
      "defaultConfiguration": "production",
      "dependsOn": ["^build"]
    },
    "serve": {
      "continuous": true,
      "executor": "@angular/build:dev-server",
      "configurations": {
        "production": {
          "buildTarget": "boxes-angular:build:production"
        },
        "development": {
          "buildTarget": "boxes-angular:build:development"
        }
      },
      "defaultConfiguration": "development",
      "dependsOn": ["^build"]
    },
    "lint": {
      "executor": "@nx/eslint:lint"
    }
  }
}
